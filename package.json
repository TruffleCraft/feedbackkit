{
  "name": "feedbackkit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Self-hosted feedback gateway — complete-at-the-source user feedback to structured, agent-ready GitHub issues.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "materialize": "node scripts/materialize-wrangler.mjs",
    "build:widget": "node scripts/build-widget.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "pnpm materialize && wrangler dev",
    "migrate:local": "wrangler d1 migrations apply feedbackkit --local",
    "migrate:remote": "wrangler d1 migrations apply feedbackkit --remote",
    "deploy": "pnpm build:widget && pnpm materialize && pnpm migrate:remote && wrangler deploy",
    "setup": "node scripts/setup.mjs"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250110.0",
    "esbuild": "^0.24.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8",
    "wrangler": "^3.99.0"
  }
}
